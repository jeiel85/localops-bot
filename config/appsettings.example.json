{
  "telegram": {
    "botToken": "ENV:HOMEBASE_TELEGRAM_TOKEN",
    "allowedChatIds": [123456789],
    "respondToUnauthorized": false,
    "pollingTimeoutSeconds": 30,
    "pollingErrorBackoffSeconds": 10,
    "parseMode": "HTML",
    "disableWebPagePreview": true
  },
  "agent": {
    "machineDisplayName": "DESKTOP-01",
    "language": "",
    "sendBootNotification": true,
    "bootNotificationDedupMinutes": 10,
    "databasePath": "%ProgramData%/Homebase/data/localops.db"
  },
  "llmAdvisor": {
    "enabled": true,
    "endpoint": "http://127.0.0.1:11434",
    "model": "llama3.2:1b",
    "timeoutSeconds": 60,
    "language": "",
    "maxTokens": 350,
    "keepAliveMinutes": 10
  },
  "temperature": {
    "enabled": true,
    "source": "Wmi"
  },
  "advisorAlerts": {
    "enabled": false,
    "intervalSeconds": 300,
    "cooldownMinutes": 60,
    "consecutiveBreaches": 2,
    "cpuPercent": 90,
    "memoryPercent": 90,
    "diskPercent": 95,
    "tempCelsius": 85
  },
  "collectors": {
    "metricIntervalSeconds": 60,
    "watchIntervalSeconds": 60,
    "eventLogPollingIntervalSeconds": 30,
    "collectorTimeoutSeconds": 5
  },
  "alerting": {
    "dedupWindowSeconds": 600,
    "maxMessagesPerMinute": 10,
    "maxMessagesPerHour": 120,
    "sendRecoveryAlerts": true,
    "criticalAlertsBypassMute": false
  },
  "disk": {
    "warnFreeBelowGb": 20,
    "criticalFreeBelowGb": 10,
    "warnUsedPercentAbove": 85,
    "criticalUsedPercentAbove": 95
  },
  "processWatches": [
    {
      "name": "Ollama",
      "processNames": ["ollama", "ollama.exe"],
      "alertWhenMissing": true,
      "minInstances": 1,
      "severity": "Warning"
    }
  ],
  "serviceWatches": [
    {
      "name": "PostgreSQL",
      "serviceName": "postgresql-x64-16",
      "expectedStatus": "Running",
      "severity": "Warning"
    }
  ],
  "eventLog": {
    "enabled": true,
    "logs": ["Application", "System"],
    "levels": ["Critical", "Error"],
    "alertLevels": ["Critical", "Error"],
    "repeatSuppressMinutes": 60,
    "providerIncludes": [],
    "providerExcludes": [],
    "messageMaxChars": 500,
    "llmInterpret": false
  },
  "notificationForwarding": {
    "enabled": false,
    "mode": "BlockList",
    "allowApps": [],
    "blockApps": [
      "1Password",
      "Bitwarden",
      "Authy",
      "Microsoft Authenticator",
      "Windows Security"
    ],
    "maskingEnabled": true,
    "maskPatterns": [
      "(?<!\\d)\\d{6}(?!\\d)",
      "(?i)(password|passwd|pwd)\\s*[:=]\\s*\\S+",
      "(?i)bearer\\s+[a-z0-9._\\-]+",
      "(?i)(token|secret|api[_-]?key)\\s*[:=]\\s*\\S+"
    ],
    "bodyMaxChars": 800,
    "toastPollingIntervalSeconds": 3
  },
  "developerMonitors": {
    "httpEndpoints": [
      {
        "name": "Local Web App",
        "url": "http://localhost:3000",
        "method": "GET",
        "timeoutSeconds": 5,
        "expectedStatusCodes": [200, 302]
      }
    ],
    "tcpPorts": [
      { "name": "PostgreSQL", "host": "127.0.0.1", "port": 5432 },
      { "name": "Ollama", "host": "127.0.0.1", "port": 11434 }
    ]
  },
  "retention": {
    "commandLogDays": 30,
    "alertLogDays": 90,
    "metricSampleDays": 7,
    "notificationEventDays": 14
  },
  "logging": {
    "level": "Information",
    "retainedFileCountLimit": 14
  }
}
