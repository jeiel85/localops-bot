{
  "deviceHub": {
    "enabled": false,
    "maxHops": 4,
    "replayWindowMinutes": 10
  },
  "transports": {
    "telegram": {
      "enabled": true,
      "useLegacySectionFallback": true
    },
    "kdeConnect": {
      "enabled": false,
      "deviceName": "Homebase PC",
      "pairingMode": "Interactive",
      "pairingTimeoutSeconds": 30,
      "certificatePath": "%ProgramData%/Homebase/security/kde-device.pfx",
      "maxConcurrentSessions": 4,
      "maxControlPacketBytes": 1048576,
      "maxPayloadBytes": 1073741824
    }
  },
  "delivery": {
    "defaultPolicy": "TelegramFallback",
    "fallbackDelaySeconds": 15,
    "criticalPolicy": "Both",
    "warningPolicy": "TelegramFallback",
    "infoPolicy": "LocalPreferred"
  },
  "pairing": {
    "allowNewDevices": true,
    "requireTrayConfirmation": true,
    "allowTelegramConfirmation": false,
    "rememberTrustedDevices": true,
    "rejectCertificateChanges": true
  },
  "sessionBridge": {
    "enabled": false,
    "pipeName": "Homebase.SessionBridge",
    "maxControlFrameBytes": 1048576,
    "heartbeatSeconds": 15,
    "requestTimeoutSeconds": 10,
    "legacyNotificationPipeFallback": true
  },
  "payloads": {
    "tempPath": "%ProgramData%/Homebase/payloads/temp",
    "userDownloadSubfolder": "Homebase",
    "maxFileBytes": 1073741824,
    "minimumFreeDiskBytes": 2147483648,
    "autoOpen": false,
    "requireConfirmationForExecutables": true
  },
  "plugins": {
    "battery": {
      "enabled": true
    },
    "mobileNotifications": {
      "enabled": true,
      "showWindowsToast": true,
      "forwardToTelegram": false,
      "storeContent": false
    },
    "share": {
      "enabled": true
    },
    "runCommand": {
      "enabled": true
    },
    "clipboard": {
      "enabled": false
    },
    "media": {
      "enabled": false
    }
  }
}
