<local:ThemedWindow xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LocalOpsBot.Tray"
        x:Class="LocalOpsBot.Tray.SettingsWindow"
        Style="{StaticResource Window.Chrome}"
        Title="Homebase"
        Icon="pack://application:,,,/Resources/homebase.ico"
        Width="460" Height="640"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Canvas}"
        FontFamily="{StaticResource Font.Sans}"
        TextOptions.TextFormattingMode="Display">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ═ Masthead: carbon command slab with wordmark + live status badge ═ -->
    <Border Grid.Row="0" Style="{StaticResource SectionHeaderBar}" Margin="0,0,0,12">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                   FontFamily="{StaticResource Font.Display}" FontWeight="Black"
                   FontSize="16" Foreground="{StaticResource Brush.OnDark}" Text="HOMEBASE"/>
        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="8,3,0,0"
                   Style="{StaticResource Type.Micro}" Foreground="{StaticResource Brush.Amber}"
                   Text="PC MONITOR"/>
        <Border x:Name="StatusBadge" DockPanel.Dock="Right" VerticalAlignment="Center"
                Background="#9E9E9E" CornerRadius="2" Padding="9,3">
          <TextBlock x:Name="AgentStatusText" Text="checking…"
                     Foreground="{StaticResource Brush.OnDark}" FontSize="11" FontWeight="Bold"/>
        </Border>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- ═ SYSTEM ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="SYSTEM"/>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="72"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Type.Label}" Text="UPTIME" Margin="0,5"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UptimeText" Style="{StaticResource Type.BodyStrong}" Text="—" Margin="0,5"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Type.Label}" Text="CPU" Margin="0,5" VerticalAlignment="Center"/>
            <Grid Grid.Row="1" Grid.Column="1" Margin="0,5">
              <ProgressBar x:Name="CpuBar" Style="{StaticResource Gauge}"/>
              <TextBlock x:Name="CpuText" Text="—" HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="11" FontWeight="Bold" Foreground="{StaticResource Brush.Ink}"/>
            </Grid>

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Type.Label}" Text="RAM" Margin="0,5" VerticalAlignment="Center"/>
            <Grid Grid.Row="2" Grid.Column="1" Margin="0,5">
              <ProgressBar x:Name="RamBar" Style="{StaticResource Gauge}"/>
              <TextBlock x:Name="RamText" Text="—" HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="11" FontWeight="Bold" Foreground="{StaticResource Brush.Ink}"/>
            </Grid>

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Type.Label}" Text="NETWORK" Margin="0,5"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="NetworkText" Style="{StaticResource Type.Body}" Text="—" Margin="0,5"/>
          </Grid>
        </Border>

        <!-- ═ DISKS ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="DISKS"/>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
          <StackPanel x:Name="DiskPanel"/>
        </Border>

        <!-- ═ NOTIFICATIONS ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="NOTIFICATIONS"/>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
          <StackPanel>
            <CheckBox x:Name="ForwardingEnabledCheckBox" Content="Enable notification forwarding"
                      IsChecked="False" Margin="0,0,0,4" Foreground="{StaticResource Brush.Ink}"/>
            <TextBlock Style="{StaticResource Type.Micro}" TextWrapping="Wrap"
                       Text="Requires Windows notification listener permission. Restart the tray app after enabling."/>
          </StackPanel>
        </Border>

        <!-- ═ ABOUT ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="ABOUT"/>
        </Border>
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock x:Name="AboutVersionText" Style="{StaticResource Type.BodyStrong}" Text="Homebase"/>
            <TextBlock Style="{StaticResource Type.Micro}" Text="Personal Windows PC monitoring for Telegram"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <Button Grid.Row="2" Style="{StaticResource Button.Carbon}" Content="CLOSE"
            HorizontalAlignment="Right" Margin="0,12,0,0" Click="Close_Click"/>
  </Grid>
</local:ThemedWindow>
