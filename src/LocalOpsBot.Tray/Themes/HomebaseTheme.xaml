<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

  <!-- ══════════════════════════════════════════════════════════════
       Homebase design system — Nintendo.com (2001) "console chrome"
       Y2K hardware faceplate: periwinkle metal plates, carbon command
       slabs, warm amber/signal reserved strictly for wayfinding.
       Source: guide/DESIGN-nintendo-2001.md
       ══════════════════════════════════════════════════════════════ -->

  <!-- ── Palette ── -->
  <Color x:Key="Color.Canvas">#FF7A8ABA</Color>
  <Color x:Key="Color.Carbon">#FF21242E</Color>
  <Color x:Key="Color.ChromeIndigo">#FF3D4F97</Color>
  <Color x:Key="Color.Signal">#FFF68D1F</Color>
  <Color x:Key="Color.Amber">#FFECAB37</Color>

  <SolidColorBrush x:Key="Brush.Canvas"       Color="#7A8ABA"/> <!-- primary chrome body -->
  <SolidColorBrush x:Key="Brush.CanvasSoft"   Color="#9FBEE7"/> <!-- pale-sky inset strip -->
  <SolidColorBrush x:Key="Brush.Periwinkle"   Color="#8BA1D4"/> <!-- raised mid panels -->
  <SolidColorBrush x:Key="Brush.Lavender"     Color="#ACACE7"/> <!-- hero / promo fields -->
  <SolidColorBrush x:Key="Brush.Ice"          Color="#C0D5E6"/>
  <SolidColorBrush x:Key="Brush.Carbon"       Color="#21242E"/> <!-- command slabs, ink -->
  <SolidColorBrush x:Key="Brush.ChromeIndigo" Color="#3D4F97"/> <!-- bevel shadow line -->
  <SolidColorBrush x:Key="Brush.MutedIndigo"  Color="#60619C"/> <!-- recessed chrome -->
  <SolidColorBrush x:Key="Brush.Platinum"     Color="#DEDEDE"/> <!-- inset list surface -->
  <SolidColorBrush x:Key="Brush.Surface"      Color="#FFFFFF"/> <!-- white cards/fields -->
  <SolidColorBrush x:Key="Brush.Hairline"     Color="#5A5F8C"/>
  <SolidColorBrush x:Key="Brush.Amber"        Color="#ECAB37"/> <!-- utility chips/badges -->
  <SolidColorBrush x:Key="Brush.Signal"       Color="#F68D1F"/> <!-- forward / submit -->
  <SolidColorBrush x:Key="Brush.NavGold"      Color="#E48600"/> <!-- nav words / pressed -->
  <SolidColorBrush x:Key="Brush.Primary"      Color="#E60012"/> <!-- brand red / alert -->
  <SolidColorBrush x:Key="Brush.Ink"          Color="#21242E"/> <!-- text on light -->
  <SolidColorBrush x:Key="Brush.InkSoft"      Color="#3D4F97"/> <!-- secondary text -->
  <SolidColorBrush x:Key="Brush.OnDark"       Color="#FFFFFF"/> <!-- text on carbon/warm -->
  <SolidColorBrush x:Key="Brush.SystemsTeal"  Color="#206479"/>

  <!-- Semantic status — cool by default; warm/red only at thresholds -->
  <SolidColorBrush x:Key="Brush.StatusOk"   Color="#3D4F97"/> <!-- chrome-indigo (normal) -->
  <SolidColorBrush x:Key="Brush.StatusWarn" Color="#ECAB37"/> <!-- amber (elevated) -->
  <SolidColorBrush x:Key="Brush.StatusBad"  Color="#E60012"/> <!-- brand red (critical) -->
  <SolidColorBrush x:Key="Brush.StatusOnline"  Color="#2E7D32"/>
  <SolidColorBrush x:Key="Brush.StatusOffline" Color="#E60012"/>

  <FontFamily x:Key="Font.Sans">Arial</FontFamily>
  <FontFamily x:Key="Font.Display">Arial Black</FontFamily>

  <!-- ── Typography ──
       The chrome voice is uppercase Arial Bold; callers pass already-
       uppercased text for section labels (WPF has no text-transform). -->
  <Style x:Key="Type.SectionLabel" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.OnDark}"/>
  </Style>
  <Style x:Key="Type.Body" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Ink}"/>
  </Style>
  <Style x:Key="Type.BodyStrong" TargetType="TextBlock" BasedOn="{StaticResource Type.Body}">
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>
  <Style x:Key="Type.Micro" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.InkSoft}"/>
  </Style>
  <Style x:Key="Type.Label" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.InkSoft}"/>
  </Style>
  <Style x:Key="Type.Wordmark" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
    <Setter Property="FontWeight" Value="Black"/>
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.OnDark}"/>
  </Style>

  <!-- ── Plates & Cards ──
       Depth is physical bevel, not soft shadow: a chrome-indigo shadow
       line beneath every plate (thicker bottom border approximates it). -->
  <Style x:Key="Plate" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Brush.Canvas}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.ChromeIndigo}"/>
    <Setter Property="BorderThickness" Value="1,1,1,2"/>
    <Setter Property="Padding" Value="12"/>
  </Style>
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Hairline}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10"/>
  </Style>
  <Style x:Key="SectionHeaderBar" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Brush.Carbon}"/>
    <Setter Property="Padding" Value="8,4"/>
  </Style>

  <!-- ── Buttons ── -->
  <!-- Amber utility button (Go / tools); presses to nav-gold -->
  <Style x:Key="Button.Amber" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource Brush.Carbon}"/>
    <Setter Property="Background" Value="{StaticResource Brush.Amber}"/>
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="2"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.NavGold}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Signal forward/submit button (white text) -->
  <Style x:Key="Button.Signal" TargetType="Button" BasedOn="{StaticResource Button.Amber}">
    <Setter Property="Foreground" Value="{StaticResource Brush.OnDark}"/>
    <Setter Property="Background" Value="{StaticResource Brush.Signal}"/>
    <Setter Property="Padding" Value="16,8"/>
  </Style>

  <!-- Carbon secondary/command button (sharp corners) -->
  <Style x:Key="Button.Carbon" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource Brush.OnDark}"/>
    <Setter Property="Background" Value="{StaticResource Brush.Carbon}"/>
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="0"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.MutedIndigo}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Gauge (CPU / RAM) — inset platinum track, chrome-indigo fill.
       Foreground is overridden per-threshold in code (ok/warn/bad). -->
  <Style x:Key="Gauge" TargetType="ProgressBar">
    <Setter Property="Height" Value="16"/>
    <Setter Property="Background" Value="{StaticResource Brush.Platinum}"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.StatusOk}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Hairline}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Minimum" Value="0"/>
    <Setter Property="Maximum" Value="100"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="0">
            <Grid ClipToBounds="True">
              <Border x:Name="PART_Track"/>
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                      Background="{TemplateBinding Foreground}"/>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Text field — white inset, hairline border, signal focus ring.
       Implicit (no key) so every TextBox picks up the chrome automatically. -->
  <Style TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
    <Setter Property="Foreground" Value="{StaticResource Brush.Ink}"/>
    <Setter Property="CaretBrush" Value="{StaticResource Brush.Ink}"/>
    <Setter Property="SelectionBrush" Value="{StaticResource Brush.Amber}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Hairline}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,4"/>
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Brush.Signal}"/>
              <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Checkbox — carbon-outlined square, signal check. Implicit (no key). -->
  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource Brush.Ink}"/>
    <Setter Property="FontFamily" Value="{StaticResource Font.Sans}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" Background="Transparent">
            <Border x:Name="box" Width="16" Height="16" VerticalAlignment="Center"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" CornerRadius="2">
              <Path x:Name="check" Visibility="Collapsed" Stretch="Uniform" Margin="3"
                    Data="M 0 5 L 4 9 L 11 0" Stroke="{StaticResource Brush.Signal}" StrokeThickness="2"
                    StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
            </Border>
            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="check" Property="Visibility" Value="Visible"/>
              <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Signal}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Signal}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── Scrollbar — thin chrome rail, indigo thumb. Keeps the standard Track/Thumb/
       RepeatButton structure (scroll behaviour intact); only the visuals change. -->
  <Style x:Key="ScrollThumb" TargetType="Thumb">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border Background="{StaticResource Brush.MutedIndigo}" CornerRadius="4" Margin="2"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="ScrollPage" TargetType="RepeatButton">
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="IsTabStop" Value="False"/>
    <Setter Property="Opacity" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="{StaticResource Brush.CanvasSoft}"/>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Vertical">
        <Setter Property="Width" Value="11"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Border Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPage}" Command="ScrollBar.PageUpCommand"/>
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}"/>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPage}" Command="ScrollBar.PageDownCommand"/>
                  </Track.IncreaseRepeatButton>
                </Track>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="11"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Border Background="{TemplateBinding Background}">
                <Track x:Name="PART_Track">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPage}" Command="ScrollBar.PageLeftCommand"/>
                  </Track.DecreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}"/>
                  </Track.Thumb>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPage}" Command="ScrollBar.PageRightCommand"/>
                  </Track.IncreaseRepeatButton>
                </Track>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ══ Custom window chrome — carbon title bar with themed caption buttons ══
       Applied via the Window.Chrome style below. WindowChrome keeps the title-bar drag,
       Aero-Snap and taskbar behaviour native; the tray windows are CanMinimize / NoResize,
       so only minimize + close show. Caption buttons are wired in code
       (ThemedWindow.OnApplyTemplate) by their PART_ names. -->

  <!-- Min caption button: flat, indigo hover. -->
  <Style x:Key="CaptionButton" TargetType="Button">
    <Setter Property="Width" Value="44"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="Transparent">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.MutedIndigo}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <!-- Close caption button: same shape, brand-red hover. -->
  <Style x:Key="CaptionCloseButton" TargetType="Button">
    <Setter Property="Width" Value="44"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bg" Background="Transparent">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.Primary}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Window.Chrome" TargetType="Window">
    <Setter Property="WindowStyle" Value="None"/>
    <Setter Property="Background" Value="{StaticResource Brush.Canvas}"/>
    <Setter Property="shell:WindowChrome.WindowChrome">
      <Setter.Value>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Window">
          <Border Background="{StaticResource Brush.Carbon}"
                  BorderBrush="{StaticResource Brush.ChromeIndigo}" BorderThickness="1">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <!-- Title bar (carbon). The caption area is draggable via WindowChrome; only the
                   buttons opt out with IsHitTestVisibleInChrome so they stay clickable. -->
              <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                  <Image Source="{TemplateBinding Icon}" Width="16" Height="16" VerticalAlignment="Center"/>
                  <TextBlock Text="{TemplateBinding Title}" Margin="8,0,0,0" VerticalAlignment="Center"
                             FontFamily="{StaticResource Font.Sans}" FontWeight="Bold" FontSize="12"
                             Foreground="{StaticResource Brush.OnDark}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                  <Button x:Name="PART_Minimize" Style="{StaticResource CaptionButton}">
                    <Path Data="M0,5 H10" Stroke="{StaticResource Brush.OnDark}" StrokeThickness="1"/>
                  </Button>
                  <Button x:Name="PART_Close" Style="{StaticResource CaptionCloseButton}">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{StaticResource Brush.OnDark}" StrokeThickness="1.1"/>
                  </Button>
                </StackPanel>
              </Grid>

              <!-- Content (canvas body) -->
              <Border Grid.Row="1" Background="{TemplateBinding Background}">
                <ContentPresenter/>
              </Border>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
