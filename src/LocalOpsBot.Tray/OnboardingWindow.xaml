<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LocalOpsBot.Tray.OnboardingWindow"
        Title="Homebase — Welcome"
        Icon="pack://application:,,,/Resources/homebase.ico"
        Width="460" Height="640"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Canvas}"
        FontFamily="{StaticResource Font.Sans}"
        TextOptions.TextFormattingMode="Display">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ═ Masthead: carbon command slab ═ -->
    <Border Grid.Row="0" Style="{StaticResource SectionHeaderBar}" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <TextBlock VerticalAlignment="Center"
                   FontFamily="{StaticResource Font.Display}" FontWeight="Black"
                   FontSize="16" Foreground="{StaticResource Brush.OnDark}" Text="HOMEBASE"/>
        <TextBlock VerticalAlignment="Center" Margin="8,3,0,0"
                   Style="{StaticResource Type.Micro}" Foreground="{StaticResource Brush.Amber}"
                   Text="WELCOME"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>

        <!-- ═ Welcome bubble (mascot-style rounded card) ═ -->
        <Border Background="{StaticResource Brush.Surface}" CornerRadius="10" Padding="12"
                BorderBrush="{StaticResource Brush.Hairline}" BorderThickness="1" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Style="{StaticResource Type.BodyStrong}" Text="Welcome to Homebase!"/>
            <TextBlock Style="{StaticResource Type.Body}" TextWrapping="Wrap" Margin="0,4,0,0"
                       Text="Let's make sure your PC is talking to Telegram. Here's what's ready and what still needs setup."/>
          </StackPanel>
        </Border>

        <!-- ═ CONNECTION checklist ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="CONNECTION"/>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
          <StackPanel>

            <!-- Agent service -->
            <Grid Margin="0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="ServiceChip" Grid.Column="0" Width="76" Padding="7,3" CornerRadius="2"
                      VerticalAlignment="Center" Background="{StaticResource Brush.Hairline}">
                <TextBlock x:Name="ServiceChipText" Text="…" HorizontalAlignment="Center"
                           Foreground="{StaticResource Brush.OnDark}" FontSize="10" FontWeight="Bold"/>
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Type.BodyStrong}" Text="Agent service"/>
                <TextBlock x:Name="ServiceStatusText" Style="{StaticResource Type.Micro}"
                           TextWrapping="Wrap" Text="checking…"/>
              </StackPanel>
            </Grid>

            <!-- Bot token -->
            <Grid Margin="0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="TokenChip" Grid.Column="0" Width="76" Padding="7,3" CornerRadius="2"
                      VerticalAlignment="Center" Background="{StaticResource Brush.Hairline}">
                <TextBlock x:Name="TokenChipText" Text="…" HorizontalAlignment="Center"
                           Foreground="{StaticResource Brush.OnDark}" FontSize="10" FontWeight="Bold"/>
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Type.BodyStrong}" Text="Bot token"/>
                <TextBlock x:Name="TokenStatusText" Style="{StaticResource Type.Micro}"
                           TextWrapping="Wrap" Text="checking…"/>
              </StackPanel>
            </Grid>

            <!-- Telegram chat -->
            <Grid Margin="0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="ChatChip" Grid.Column="0" Width="76" Padding="7,3" CornerRadius="2"
                      VerticalAlignment="Center" Background="{StaticResource Brush.Hairline}">
                <TextBlock x:Name="ChatChipText" Text="…" HorizontalAlignment="Center"
                           Foreground="{StaticResource Brush.OnDark}" FontSize="10" FontWeight="Bold"/>
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Type.BodyStrong}" Text="Telegram chat"/>
                <TextBlock x:Name="ChatStatusText" Style="{StaticResource Type.Micro}"
                           TextWrapping="Wrap" Text="checking…"/>
              </StackPanel>
            </Grid>

            <!-- Credential entry: applied via a one-time elevation (writes machine env + config) -->
            <StackPanel Margin="0,10,0,0">
              <TextBlock Style="{StaticResource Type.Micro}" TextWrapping="Wrap"
                         Text="Enter your bot token and chat ID, then Save &amp; apply — this asks for admin once and restarts the service."/>
              <TextBlock Style="{StaticResource Type.Micro}" Margin="0,6,0,0" Text="Bot token"/>
              <TextBox x:Name="TokenInput" Margin="0,2,0,0" Padding="5,3"
                       FontFamily="Consolas" FontSize="12"/>
              <TextBlock Style="{StaticResource Type.Micro}" Margin="0,5,0,0" Text="Chat ID"/>
              <TextBox x:Name="ChatIdInput" Margin="0,2,0,0" Padding="5,3"
                       FontFamily="Consolas" FontSize="12"/>
              <Button x:Name="SaveApplyButton" Style="{StaticResource Button.Signal}"
                      Content="SAVE &amp; APPLY" Margin="0,7,0,0" HorizontalAlignment="Left"
                      Click="SaveApply_Click"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <Button x:Name="TestButton" Style="{StaticResource Button.Signal}"
                      Content="SEND TEST MESSAGE" Click="TestMessage_Click"/>
              <Button x:Name="RecheckButton" Style="{StaticResource Button.Amber}"
                      Content="RE-CHECK" Margin="8,0,0,0" Click="Recheck_Click"/>
            </StackPanel>
            <TextBlock x:Name="TestResultText" Style="{StaticResource Type.Micro}"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>

        <!-- ═ AI ADVICE (Ollama) checklist ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="AI ADVICE · OPTIONAL"/>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
          <StackPanel>

            <!-- Ollama status -->
            <Grid Margin="0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="OllamaChip" Grid.Column="0" Width="76" Padding="7,3" CornerRadius="2"
                      VerticalAlignment="Center" Background="{StaticResource Brush.Hairline}">
                <TextBlock x:Name="OllamaChipText" Text="…" HorizontalAlignment="Center"
                           Foreground="{StaticResource Brush.OnDark}" FontSize="10" FontWeight="Bold"/>
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Type.BodyStrong}" Text="Local AI (Ollama)"/>
                <TextBlock x:Name="OllamaStatusText" Style="{StaticResource Type.Micro}"
                           TextWrapping="Wrap" Text="checking…"/>
              </StackPanel>
            </Grid>

            <!-- Install hint: server unreachable -->
            <StackPanel x:Name="OllamaInstallHint" Visibility="Collapsed" Margin="0,8,0,0">
              <TextBlock Style="{StaticResource Type.Micro}" TextWrapping="Wrap"
                         Text="Install Ollama and start it to enable /advise and automatic health advice."/>
              <TextBlock Margin="0,4,0,0" FontFamily="{StaticResource Font.Sans}" FontSize="12" FontWeight="Bold">
                <Hyperlink NavigateUri="https://ollama.com/download"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{StaticResource Brush.InkSoft}">Get Ollama</Hyperlink>
              </TextBlock>
            </StackPanel>

            <!-- Pull hint: model not installed -->
            <StackPanel x:Name="OllamaPullHint" Visibility="Collapsed" Margin="0,8,0,0">
              <TextBlock Style="{StaticResource Type.Micro}" TextWrapping="Wrap"
                         Text="The server is running — pull the model to finish:"/>
              <TextBlock x:Name="OllamaPullCommand" FontFamily="Consolas" FontSize="12" Margin="0,3,0,0"
                         Foreground="{StaticResource Brush.Ink}" TextWrapping="Wrap" Text="ollama pull …"/>
              <Button x:Name="OllamaPullButton" Style="{StaticResource Button.Amber}"
                      Content="RUN PULL" Margin="0,6,0,0" HorizontalAlignment="Left" Click="OllamaPull_Click"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- ═ GUIDANCE ═ -->
        <Border Style="{StaticResource SectionHeaderBar}">
          <TextBlock Style="{StaticResource Type.SectionLabel}" Text="FIRST TIME?"/>
        </Border>
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Style="{StaticResource Type.Body}" TextWrapping="Wrap"
                       Text="1. Create a bot with BotFather and copy its token."/>
            <TextBlock Style="{StaticResource Type.Body}" TextWrapping="Wrap" Margin="0,3,0,0"
                       Text="2. Send your bot any message so it can learn your chat ID."/>
            <TextBlock Style="{StaticResource Type.Body}" TextWrapping="Wrap" Margin="0,3,0,0"
                       Text="3. Enter your token and chat ID above, then click Save &amp; apply."/>
            <TextBlock Margin="0,8,0,0" FontFamily="{StaticResource Font.Sans}" FontSize="12" FontWeight="Bold">
              <Hyperlink NavigateUri="https://t.me/botfather"
                         RequestNavigate="Hyperlink_RequestNavigate"
                         Foreground="{StaticResource Brush.InkSoft}">Open @BotFather</Hyperlink>
            </TextBlock>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- ═ Footer ═ -->
    <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
      <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="250"
                 Style="{StaticResource Type.Micro}" TextWrapping="Wrap"
                 Text="To change your token or chat ID later, update them above and Save &amp; apply."/>
      <Button DockPanel.Dock="Right" Style="{StaticResource Button.Carbon}"
              Content="GET STARTED" Click="GetStarted_Click"/>
    </DockPanel>
  </Grid>
</Window>
